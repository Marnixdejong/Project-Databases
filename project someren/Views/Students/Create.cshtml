
@model project_someren.Models.Student
@{ ViewData["Title"] = "Create Student"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-success text-white rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Create New Student</h3>
            </div>
            <div class="card-body p-5 bg-light">
                <form asp-action="Create">
                    
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="StudentNumber" type="text" class="form-control" placeholder="StudentNumber" required />
                <label asp-for="StudentNumber"></label>
                <span asp-validation-for="StudentNumber" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Class" type="text" class="form-control" placeholder="Class" required />
                <label asp-for="Class"></label>
                <span asp-validation-for="Class" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Person.FirstName" type="text" class="form-control" placeholder="FirstName" required />
                <label asp-for="Person.FirstName">First Name</label>
                <span asp-validation-for="Person.FirstName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Person.LastName" type="text" class="form-control" placeholder="LastName" required />
                <label asp-for="Person.LastName">Last Name</label>
                <span asp-validation-for="Person.LastName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Person.TelephoneNumber" type="text" class="form-control" placeholder="TelephoneNumber" required />
                <label asp-for="Person.TelephoneNumber">Telephone Number</label>
                <span asp-validation-for="Person.TelephoneNumber" class="text-danger"></span>
            </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                        <button type="submit" class="btn btn-success rounded-pill px-5 shadow">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
