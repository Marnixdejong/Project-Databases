
@model project_someren.Models.Activity
@{ ViewData["Title"] = "Create Activity"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-success text-white rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Create New Activity</h3>
            </div>
            <div class="card-body p-5 bg-light">
                <form asp-action="Create">
                    
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Name" type="text" class="form-control" placeholder="Name" required />
                <label asp-for="Name"></label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="StartTime" type="datetime-local" class="form-control" placeholder="StartTime" required />
                <label asp-for="StartTime"></label>
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="EndTime" type="datetime-local" class="form-control" placeholder="EndTime" required />
                <label asp-for="EndTime"></label>
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                        <button type="submit" class="btn btn-success rounded-pill px-5 shadow">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
