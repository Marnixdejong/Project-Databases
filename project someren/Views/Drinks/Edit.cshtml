@model project_someren.Models.Drink
@{ ViewData["Title"] = "Edit Drink"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Drink</h3>
            </div>
            <div class="card-body p-5 bg-light">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div class="form-floating mb-3 shadow-sm rounded">
                        <input asp-for="Name" type="text" class="form-control" placeholder="Name" required />
                        <label asp-for="Name"></label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3 shadow-sm rounded">
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Price" required />
                        <label asp-for="Price"></label>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3 shadow-sm rounded">
                        <input asp-for="VatRate" type="number" step="0.01" class="form-control" placeholder="VAT Rate" required />
                        <label asp-for="VatRate">VAT Rate (%)</label>
                        <span asp-validation-for="VatRate" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3 shadow-sm rounded">
                        <input asp-for="Stock" type="number" class="form-control" placeholder="Stock" required />
                        <label asp-for="Stock"></label>
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
