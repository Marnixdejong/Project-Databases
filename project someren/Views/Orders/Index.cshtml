@{ ViewData["Title"] = "Place Order"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        @if (TempData["Success"] != null) {
            <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null) {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold"><i class="bi bi-cart-plus me-2"></i>Place Drink Order</h3>
            </div>
            <div class="card-body p-5 bg-light">
                <form asp-action="PlaceOrder" method="post">
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted">Select Student</label>
                            <select name="studentId" class="form-select form-select-lg shadow-sm rounded-3" asp-items="ViewBag.Students" required>
                                <option value="">-- Choose Student --</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold text-muted">Select Drink</label>
                            <select name="drinkId" class="form-select form-select-lg shadow-sm rounded-3" asp-items="ViewBag.Drinks" required>
                                <option value="">-- Choose Drink --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Quantity</label>
                            <input name="quantity" type="number" class="form-control form-select-lg shadow-sm rounded-3" min="1" value="1" required />
                        </div>
                    </div>
                    <div class="text-center mt-5">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm fw-bold">
                            Place Order <i class="bi bi-send-fill ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
