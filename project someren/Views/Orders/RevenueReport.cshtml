@{ ViewData["Title"] = "Revenue Report"; }

<div class="mt-4 mb-5">
    <h1 class="display-5 fw-bold text-primary mb-4">Revenue Report</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 bg-primary text-white h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi- megaphone fs-1 mb-3"></i>
                    <h5 class="card-title opacity-75">Drinks Sold</h5>
                    <h2 class="display-4 fw-bold">@ViewBag.TotalSales</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 bg-success text-white h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-cash-stack fs-1 mb-3"></i>
                    <h5 class="card-title opacity-75">Total Turnover</h5>
                    <h2 class="display-4 fw-bold">@(((decimal)ViewBag.Turnover).ToString("C2"))</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 bg-info text-white h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-people-fill fs-1 mb-3"></i>
                    <h5 class="card-title opacity-75">Total Customers</h5>
                    <h2 class="display-4 fw-bold">@ViewBag.Customers</h2>
                </div>
            </div>
        </div>
    </div>
</div>
