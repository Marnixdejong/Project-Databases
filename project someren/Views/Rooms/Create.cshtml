
@model project_someren.Models.Room
@{ ViewData["Title"] = "Create Room"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-success text-white rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Create New Room</h3>
            </div>
            <div class="card-body p-5 bg-light">
                <form asp-action="Create">
                    
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="Building" type="text" class="form-control" placeholder="Building" required />
                <label asp-for="Building"></label>
                <span asp-validation-for="Building" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="RoomNumber" type="text" class="form-control" placeholder="RoomNumber" required />
                <label asp-for="RoomNumber"></label>
                <span asp-validation-for="RoomNumber" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="SquareMeters" type="number" class="form-control" placeholder="SquareMeters" required />
                <label asp-for="SquareMeters"></label>
                <span asp-validation-for="SquareMeters" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 shadow-sm rounded">
                <input asp-for="IsTeacherRoom" type="text" class="form-control" placeholder="IsTeacherRoom" required />
                <label asp-for="IsTeacherRoom"></label>
                <span asp-validation-for="IsTeacherRoom" class="text-danger"></span>
            </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                        <button type="submit" class="btn btn-success rounded-pill px-5 shadow">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
