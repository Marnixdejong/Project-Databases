@page
@model project_someren.Pages.Lecturers.IndexModel

@{
    ViewData["Title"] = "Lecturers";
}

<h1>Lecturers</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Lecturer</a>
</p>

<form method="get" class="mb-3">
    <div class="row align-items-center">
        <div class="col-auto">
            <label asp-for="FilterLastName">Filter by Last Name:</label>
        </div>
        <div class="col-auto">
            <input type="text" asp-for="FilterLastName" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear Filter</a>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Telephone Number</th>
            <th>Age</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Lecturers)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.TelephoneNumber</td>
                <td>@item.Age</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>