@page
@model project_someren.Pages.Rooms.CreateModel

@{
    ViewData["Title"] = "Create Room";
}

<h1>Create Room</h1>

<h4>Room</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Room.RoomNumber" class="control-label">Room Number</label>
                <input asp-for="Room.RoomNumber" class="form-control" />
                <span asp-validation-for="Room.RoomNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Room.NumberOfBeds" class="control-label">Number of Beds</label>
                <input asp-for="Room.NumberOfBeds" class="form-control" />
                <span asp-validation-for="Room.NumberOfBeds" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}