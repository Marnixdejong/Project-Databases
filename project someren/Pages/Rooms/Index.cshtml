@page
@model project_someren.Pages.Rooms.IndexModel

@{
    ViewData["Title"] = "Rooms";
}

<h1>Rooms</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Room</a>
</p>

<form method="get" class="mb-3">
    <div class="row align-items-center">
        <div class="col-auto">
            <label asp-for="FilterBeds">Filter by Size (Number of Beds):</label>
        </div>
        <div class="col-auto">
            <input type="number" asp-for="FilterBeds" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear Filter</a>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Room Number</th>
            <th>Number of Beds</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Rooms)
        {
            <tr>
                <td>@item.RoomNumber</td>
                <td>@item.NumberOfBeds</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>