@model IEnumerable<SomerenWeb.Models.Lecturer>
@{ ViewData["Title"] = "Lecturers"; }

<section>
    <header>
        <h1>Lecturers</h1>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <nav aria-label="Lecturer actions" class="d-flex justify-content-between align-items-center mb-3">
        <form method="get" asp-action="Index" class="d-flex gap-2" role="search">
            <label for="searchLastName" class="visually-hidden">Search by last name</label>
            <input type="text" id="searchLastName" name="searchLastName" value="@ViewData["SearchLastName"]"
                   class="form-control" placeholder="Search by last name" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </form>
        <a asp-action="Create" class="btn btn-primary">Add lecturer</a>
    </nav>

    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th scope="col">First name</th>
                <th scope="col">Last name</th>
                <th scope="col">Age</th>
                <th scope="col">Phone number</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Person?.FirstName</td>
                    <td>@item.Person?.LastName</td>
                    <td>@item.Age</td>
                    <td>@item.Person?.TelephoneNumber</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
