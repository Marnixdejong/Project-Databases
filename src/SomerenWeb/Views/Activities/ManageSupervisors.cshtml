@model SomerenWeb.Models.ActivitySupervisorsViewModel
@{ ViewData["Title"] = "Manage Supervisors - " + Model.Activity.Name; }

<section>
    <header>
        <h1>Manage Supervisors</h1>
    </header>

    <article class="mb-4">
        <h2>Activity: @Model.Activity.Name</h2>
        <p>
            <strong>Start:</strong> @Model.Activity.StartTime.ToString("dd-MM-yyyy HH:mm") &mdash;
            <strong>End:</strong> @Model.Activity.EndTime.ToString("dd-MM-yyyy HH:mm")
        </p>
    </article>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <section class="col-md-6 mb-4">
            <h3>Current Supervisors</h3>

            @if (Model.Supervisors.Any())
            {
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Phone</th>
                            <th>Age</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lecturer in Model.Supervisors)
                        {
                            <tr>
                                <td>@lecturer.Person?.FirstName</td>
                                <td>@lecturer.Person?.LastName</td>
                                <td>@lecturer.Person?.TelephoneNumber</td>
                                <td>@lecturer.Age</td>
                                <td>
                                    <a asp-action="RemoveSupervisor"
                                       asp-route-activityId="@Model.Activity.Id"
                                       asp-route-lecturerId="@lecturer.Id"
                                       class="btn btn-sm btn-danger">Remove</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No supervisors assigned yet.</p>
            }
        </section>

        <section class="col-md-6 mb-4">
            <h3>Available Lecturers</h3>

            @if (Model.NonSupervisors.Any())
            {
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Phone</th>
                            <th>Age</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lecturer in Model.NonSupervisors)
                        {
                            <tr>
                                <td>@lecturer.Person?.FirstName</td>
                                <td>@lecturer.Person?.LastName</td>
                                <td>@lecturer.Person?.TelephoneNumber</td>
                                <td>@lecturer.Age</td>
                                <td>
                                    <a asp-action="AddSupervisor"
                                       asp-route-activityId="@Model.Activity.Id"
                                       asp-route-lecturerId="@lecturer.Id"
                                       class="btn btn-sm btn-success">Add</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">All lecturers are already supervisors for this activity.</p>
            }
        </section>
    </div>

    <nav>
        <a asp-action="Index" class="btn btn-secondary">Back to Activities</a>
    </nav>
</section>
