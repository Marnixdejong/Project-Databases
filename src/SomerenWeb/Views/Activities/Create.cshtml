@model SomerenWeb.Models.Activity
@{ ViewData["Title"] = "Add activity"; }

<section>
    <header>
        <h1>Add activity</h1>
    </header>

    <form asp-action="Create" method="post">
        <fieldset>
            <legend>Activity details</legend>

            <p>
                <label for="Name">Name</label><br />
                <input asp-for="Name" id="Name" type="text" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </p>
            <p>
                <label for="StartTime">Start time</label><br />
                <input asp-for="StartTime" id="StartTime" type="datetime-local" class="form-control" required />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </p>
            <p>
                <label for="EndTime">End time</label><br />
                <input asp-for="EndTime" id="EndTime" type="datetime-local" class="form-control" required />
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </p>
        </fieldset>

        <p class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">Back to list</a>
            <button type="submit" class="btn btn-success">Create</button>
        </p>
    </form>
</section>
