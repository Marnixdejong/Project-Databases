@model IEnumerable<SomerenWeb.Models.Activity>
@{ ViewData["Title"] = "Activities"; }

<section>
    <header>
        <h1>Activities</h1>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <nav aria-label="Activity actions" class="d-flex justify-content-between align-items-center mb-3">
        <form method="get" asp-action="Index" class="d-flex gap-2" role="search">
            <label for="searchName" class="visually-hidden">Search by name</label>
            <input type="text" id="searchName" name="searchName" value="@ViewData["SearchName"]"
                   class="form-control" placeholder="Search by name" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </form>
        <a asp-action="Create" class="btn btn-primary">Add activity</a>
    </nav>

    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Start time</th>
                <th scope="col">End time</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Name</td>
                    <td>@activity.StartTime.ToString("dd-MM-yyyy HH:mm")</td>
                    <td>@activity.EndTime.ToString("dd-MM-yyyy HH:mm")</td>
                    <td class="text-end">
                        <a asp-action="ManageSupervisors" asp-route-id="@activity.Id"
                           class="btn btn-sm btn-outline-primary">Supervisors</a>
                        <a asp-action="ManageParticipants" asp-route-id="@activity.Id"
                           class="btn btn-sm btn-outline-secondary">Participants</a>
                        <a asp-action="Edit" asp-route-id="@activity.Id"
                           class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@activity.Id"
                           class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
