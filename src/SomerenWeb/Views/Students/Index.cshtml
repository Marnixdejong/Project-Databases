
@model IEnumerable<SomerenWeb.Models.Student>
@{ ViewData["Title"] = "Students"; }

<section>
    <h1>Students</h1>

    <nav aria-label="Student actions" class="d-flex justify-content-between align-items-center mb-3">
        <form method="get" asp-action="Index" class="d-flex gap-2" role="search">
            <label for="searchLastName" class="visually-hidden">Search by last name</label>
            <input type="text" id="searchLastName" name="searchLastName" value="@ViewData["SearchLastName"]" class="form-control" placeholder="Search by last name" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </form>
        <a asp-action="Create" class="btn btn-primary">Add student</a>
    </nav>

    <table class="table">
        <thead>
            <tr>
                <th scope="col">Student number</th>
                <th scope="col">Class</th>
                <th scope="col">First name</th>
                <th scope="col">Last name</th>
                <th scope="col">Phone number</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.StudentNumber</td>
                <td>@item.Class</td>
                <td>@item.Person?.FirstName</td>
                <td>@item.Person?.LastName</td>
                <td>@item.Person?.TelephoneNumber</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
