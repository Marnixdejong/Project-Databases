
@model SomerenWeb.Models.Student
@{ ViewData["Title"] = "Edit student"; }

<section>
    <h1>Edit student</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Person.Id" />

        <fieldset>
            <legend>Student details</legend>

            <p>
                <label for="StudentNumber">Student number</label><br />
                <input asp-for="StudentNumber" id="StudentNumber" type="text" class="form-control" required />
                <span asp-validation-for="StudentNumber" class="text-danger"></span>
            </p>
            <p>
                <label for="Class">Class</label><br />
                <input asp-for="Class" id="Class" type="text" class="form-control" required />
                <span asp-validation-for="Class" class="text-danger"></span>
            </p>
            <p>
                <label for="Person_FirstName">First name</label><br />
                <input asp-for="Person.FirstName" id="Person_FirstName" type="text" class="form-control" required />
                <span asp-validation-for="Person.FirstName" class="text-danger"></span>
            </p>
            <p>
                <label for="Person_LastName">Last name</label><br />
                <input asp-for="Person.LastName" id="Person_LastName" type="text" class="form-control" required />
                <span asp-validation-for="Person.LastName" class="text-danger"></span>
            </p>
            <p>
                <label for="Person_TelephoneNumber">Phone number</label><br />
                <input asp-for="Person.TelephoneNumber" id="Person_TelephoneNumber" type="text" class="form-control" />
                <span asp-validation-for="Person.TelephoneNumber" class="text-danger"></span>
            </p>
        </fieldset>

        <p class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">Back to list</a>
            <button type="submit" class="btn btn-primary">Save</button>
        </p>
    </form>
</section>
